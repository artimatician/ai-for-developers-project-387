{
  "name": "frontend",
  "version": "0.1.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "build:spec": "cd ../spec && npx tsp compile main.tsp",
    "mock:api": "npm run build:spec && prism mock ../spec/tsp-output/@typespec/openapi3/openapi.yaml --port 4010 --host 0.0.0.0",
